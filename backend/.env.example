# App
APP_ENV=development
APP_NAME=AI Spend Audit Tool API
APP_CORS_ORIGINS=http://localhost:5173
# Use the psycopg (v3) driver. If you use plain `postgresql://...`, SQLAlchemy may try `psycopg2`.
DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/ai_spend_audit

# NVIDIA (AI summary) - optional
NVIDIA_API_KEY=
NVIDIA_MODEL=
# Advanced: override only if needed
NVIDIA_CHAT_COMPLETIONS_URL=https://integrate.api.nvidia.com/v1/chat/completions

# SMTP (lead confirmation) - optional
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=true

# Sharing (Step 7)
FRONTEND_PUBLIC_BASE_URL=http://localhost:5173
